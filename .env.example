# Copy to .env and fill secrets. Never commit real secrets.
DB_USER=docpro
DB_PASSWORD=docpro_secret
DB_NAME=docpro

MINIO_ROOT_USER=docpro
MINIO_ROOT_PASSWORD=docpro_secret
MINIO_BUCKET=docpro-person

# App
DATABASE_URL=postgres://docpro:docpro_secret@localhost:5432/docpro
MINIO_ENDPOINT=http://localhost:9000
SESSION_SECRET=change_me

# ==========================
# AI Provider
# ==========================

AI_URL=https://ai.sumopod.com
AI_KEY=
AI_MODEL=deepseek-v4-flash

# ==========================
# Embedding (Ollama lokal — nomic-embed-text, 768-dim)
# ==========================

EMBEDDING_URL=http://localhost:11434/api/embeddings
EMBEDDING_MODEL=nomic-embed-text

# ==========================
# Google OAuth (login SSO)
# ==========================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
